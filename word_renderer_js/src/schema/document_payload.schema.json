{
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "hexColor": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]{6}$"
    }
  },
  "required": [
    "version",
    "render_mode",
    "document_id",
    "metadata",
    "blocks"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "render_mode": {
      "type": "string",
      "const": "structured"
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string"
    },
    "format": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "required": [
        "title",
        "theme_name",
        "table_template",
        "density",
        "document_style",
        "header_footer"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "preferred_filename": {
          "type": "string"
        },
        "theme_name": {
          "type": "string"
        },
        "table_template": {
          "type": "string"
        },
        "density": {
          "type": "string"
        },
        "accent_color": {
          "anyOf": [
            {
              "$ref": "#/definitions/hexColor"
            },
            {
              "type": "string",
              "const": ""
            }
          ]
        },
        "document_style": {
          "type": "object",
          "properties": {
            "font_name": {
              "type": "string"
            },
            "heading_font_name": {
              "type": "string"
            },
            "table_font_name": {
              "type": "string"
            },
            "code_font_name": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "header_footer": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "const": "hero_banner"
                }
              }
            },
            "then": {
              "required": [
                "title"
              ],
              "properties": {
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "subtitle": {
                  "type": "string"
                },
                "theme_color": {
                  "$ref": "#/definitions/hexColor"
                },
                "text_color": {
                  "$ref": "#/definitions/hexColor"
                },
                "subtitle_color": {
                  "$ref": "#/definitions/hexColor"
                },
                "min_height_pt": {
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "maximum": 240
                },
                "full_width": {
                  "type": "boolean"
                }
              }
            }
          }
        ],
        "additionalProperties": true
      }
    }
  }
}
